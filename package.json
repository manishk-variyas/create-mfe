{
  "name": "create-mfe",
  "version": "1.0.0",
  "description": "CLI to scaffold Vite + React microfrontend monorepos with Module Federation",
  "main": "dist/index.js",
  "bin": {
    "create-mfe": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "docs:dev": "npm run --prefix docs dev",
    "dev:docs": "npm run docs:dev",
    "docs:build": "npm run --prefix docs build",
    "docs:preview": "npm run --prefix docs preview"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "enquirer": "^2.4.1",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "ora": "^7.0.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
